# ────────────────────────────────────────────────
# .dockerignore
# Keep build context lean: exclude everything that
# is either mounted as a volume at runtime or is
# irrelevant to the image build.
# ────────────────────────────────────────────────

# Git / VCS
.git/
.gitignore

# CI / tooling
.github/
.vscode/
.idea/
*.swp
*.swo
*~

# Docker files (no need to copy into image)
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
*.md

# Python byte-code & test artefacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
*.log

# Virtual environments (host-side only)
.venv/
venv/
env/
ENV/
webKinPredEnv/

# OS noise
.DS_Store
._*
Thumbs.db

# Secrets / local config
.env*
keys/

# ── Frontend ──────────────────────────────────────
# Built assets and deps handled inside frontend image
frontend/node_modules/
frontend/build/
frontend/.next/
frontend/.env*

# ── Django static / media ────────────────────────
# staticfiles is collectstatic output – regenerated at runtime
staticfiles/
# media is a runtime volume
media/

# ── SQLite databases (runtime data, not part of image) ──
*.sqlite3
celerybeat-schedule

# ── Jupyter / notebooks ──────────────────────────
**/.ipynb_checkpoints/
*.ipynb

# ── fastas / sequence DBs ────────────────────────
# Large FASTA databases are mounted as volumes
fastas/dbs/

# ── Large model weights (mounted as volumes at runtime) ──

# EITLEM
models/EITLEM/Weights/

# TurNup (entire data dir; saved_models mounted separately)
models/TurNup/data/

# UniKP
models/UniKP-main/models/

# DLKcat
models/DLKcat/DeeplearningApproach/Data/
models/DLKcat/DeeplearningApproach/Results/
models/DLKcat/BayesianApproach/

# KinForm trained models (mounted as volume)
models/KinForm/results/

# ── Test / dev scripts (not needed in image) ─────
test_*.py
test_*.csv
tests/
