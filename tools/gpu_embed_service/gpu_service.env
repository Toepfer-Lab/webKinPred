export GPU_EMBED_REPO_ROOT=/home/msp/webKinPred
export GPU_EMBED_SERVICE_TOKEN=
export GPU_NAME=RTX-A4500

export KINFORM_MEDIA_PATH=/mnt/webkinpred/media
export KINFORM_TOOLS_PATH=/home/msp/webKinPred/tools
export KINFORM_DATA=/home/msp/webKinPred/models/KinForm/results
export KINFORM_ESM_PATH=/home/msp/miniconda3/envs/esm/bin/python
export KINFORM_ESMC_PATH=/home/msp/miniconda3/envs/esmc/bin/python
export KINFORM_T5_PATH=/home/msp/miniconda3/envs/prot_t5/bin/python
export KINFORM_PSEQ2SITES_PATH=/home/msp/miniconda3/envs/pseq2sites/bin/python
export KINFORM_T5_MODEL_PATH=/home/msp/models/prot_t5_xl_uniref50
export TURNUP_DATA_PATH=/home/msp/webKinPred/models/TurNup/data

_RUN_STEP="/usr/bin/python3 /home/msp/webKinPred/tools/gpu_embed_service/run_step.py"
_COMMON="--seq-ids {seq_ids} --seq-id-to-seq-file {seq_id_to_seq_file}"

export GPU_EMBED_STEP_CMD_KINFORM_T5_FULL="$_RUN_STEP --step kinform_t5_full $_COMMON"
export GPU_EMBED_STEP_CMD_KINFORM_ESM2_LAYERS="$_RUN_STEP --step kinform_esm2_layers $_COMMON"
export GPU_EMBED_STEP_CMD_KINFORM_ESMC_LAYERS="$_RUN_STEP --step kinform_esmc_layers $_COMMON"
export GPU_EMBED_STEP_CMD_PROT_T5_MEAN="$_RUN_STEP --step prot_t5_mean $_COMMON"
export GPU_EMBED_STEP_CMD_TURNUP_ESM1B="$_RUN_STEP --step turnup_esm1b $_COMMON"

unset _RUN_STEP _COMMON
