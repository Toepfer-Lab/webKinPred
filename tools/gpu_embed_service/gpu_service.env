export GPU_EMBED_REPO_ROOT=/home/msp/webKinPred
export GPU_EMBED_SERVICE_TOKEN=
export GPU_NAME=RTX-A4500

export KINFORM_MEDIA_PATH=/mnt/webkinpred/media
export KINFORM_TOOLS_PATH=/home/msp/webKinPred/tools
export KINFORM_DATA=/home/msp/webKinPred/models/KinForm/results
export KINFORM_ESM_PATH=/home/msp/miniconda3/envs/esm/bin/python
export KINFORM_ESMC_PATH=/home/msp/miniconda3/envs/esmc/bin/python
export KINFORM_T5_PATH=/home/msp/miniconda3/envs/prot_t5/bin/python
export KINFORM_PSEQ2SITES_PATH=/home/msp/miniconda3/envs/pseq2sites/bin/python
export KINFORM_T5_MODEL_PATH=/home/msp/models/prot_t5_xl_uniref50
export KINFORM_PARALLEL_EMBED_ENABLE=1
export KINFORM_PARALLEL_EMBED_ALLOW_LEGACY_FALLBACK=0
export KINFORM_PARALLEL_STREAM_ENABLE=1
export KINFORM_PARALLEL_STREAM_ALLOW_LEGACY_FALLBACK=0
export KINFORM_REQUIRE_CUDA=1
export KINFORM_PARALLEL_RESIDUE_CACHE_GB=6
export KINFORM_PARALLEL_SPILL_DIR=/dev/shm/webkinpred-kinform
export KINFORM_PARALLEL_SPILL_FALLBACK_DIR=/tmp/webkinpred-kinform
export KINFORM_PARALLEL_PSEQ_STREAM_BATCH_SIZE=16
export KINFORM_PARALLEL_PSEQ_STREAM_QUEUE_SIZE=256
export KINFORM_PARALLEL_PSEQ_STREAM_QUEUE_SIZE_CAP=256
export KINFORM_PARALLEL_PSEQ_STREAM_IDLE_FLUSH_SECONDS=0.10
export KINFORM_PARALLEL_PSEQ_STREAM_PERSIST_EVERY_ROWS=128
export KINFORM_PARALLEL_PSEQ_STREAM_PERSIST_EVERY_SECONDS=30
export KINFORM_PARALLEL_PSEQ_STREAM_READ_EXISTING_ON_START=0
export KINFORM_PARALLEL_PSEQ_SENDS_PER_TICK=512
export KINFORM_PARALLEL_PSEQ_SEND_QUEUE_SIZE=256
export KINFORM_PARALLEL_ASYNC_WRITE_WORKERS=16
export KINFORM_PARALLEL_BS_CACHE_LOAD_WORKERS=24
export KINFORM_PARALLEL_STREAM_MAX_EVENTS_PER_TICK=1024
export KINFORM_PARALLEL_STREAM_RECV_TIMEOUT_SECONDS=0.02
export KINFORM_PARALLEL_STREAM_TSV_REFRESH_ENABLE=0
export KINFORM_PARALLEL_TSV_REFRESH_SECONDS=30
export KINFORM_PARALLEL_WORKER_DONE_WAIT_SECONDS=10
export KINFORM_PARALLEL_STREAM_SOCKET_DIR=/tmp/webkinpred-gpu-embed/kinform
export KINFORM_STREAM_WRITE_MEAN_FILES=0
# Optional stream debugging compatibility toggle:
# export KINFORM_PARALLEL_STREAM_LEGACY_RESIDUE_WRITE=1
# Optional: debug | info | warning | error | quiet
# export KINFORM_PARALLEL_LOG_LEVEL=info
export TURNUP_DATA_PATH=/home/msp/webKinPred/models/TurNup/data

export EITLEM_EMBED_PYTHON=/home/msp/miniconda3/envs/eitlem_env/bin/python

export CATPRED_EMBED_PYTHON=/home/msp/miniconda3/envs/catpred_env/bin/python
export CATPRED_CHECKPOINT_ROOT=/home/msp/models/catpred/pretrained/production

_RUN_STEP="/usr/bin/python3 /home/msp/webKinPred/tools/gpu_embed_service/run_step.py"
_COMMON="--seq-ids {seq_ids} --seq-id-to-seq-file {seq_id_to_seq_file} --job-id {job_id}"

# Dedicated per-job worker logs (separate from access logs)
export GPU_EMBED_JOB_LOG_DIR=/tmp/webkinpred-gpu-embed/jobs

export GPU_EMBED_STEP_CMD_KINFORM_T5_FULL="$_RUN_STEP --step kinform_t5_full $_COMMON"
export GPU_EMBED_STEP_CMD_KINFORM_ESM2_LAYERS="$_RUN_STEP --step kinform_esm2_layers $_COMMON"
export GPU_EMBED_STEP_CMD_KINFORM_ESMC_LAYERS="$_RUN_STEP --step kinform_esmc_layers $_COMMON"
export GPU_EMBED_STEP_CMD_PROT_T5_MEAN="$_RUN_STEP --step prot_t5_mean $_COMMON"
export GPU_EMBED_STEP_CMD_TURNUP_ESM1B="$_RUN_STEP --step turnup_esm1b $_COMMON"
export GPU_EMBED_STEP_CMD_EITLEM_ESM1V="$_RUN_STEP --step eitlem_esm1v $_COMMON"
export GPU_EMBED_STEP_CMD_CATPRED_EMBED_KCAT="$_RUN_STEP --step catpred_embed_kcat $_COMMON"
export GPU_EMBED_STEP_CMD_CATPRED_EMBED_KM="$_RUN_STEP --step catpred_embed_km $_COMMON"

unset _RUN_STEP _COMMON
